        ;
        ; Standard SUBLEQ macros and functions
        ;

        .include IO.inc
        .include STRING.inc
        .include CONSTANTS.inc
        .include STACK.inc

        ;
        ; Subroutines for the BASIC commands
        ;

        .include subasic/cmdEND.inc
        .include subasic/cmdREM.inc
        .include subasic/cmdPRINT.inc
        .include subasic/cmdGOTO.inc
        .include subasic/cmdIF.inc
        .include subasic/cmdLET.inc
        .include subasic/cmdGOSUB.inc
        .include subasic/cmdRETURN.inc
        .include subasic/cmdFOR.inc
        .include subasic/cmdNEXT.inc
        .include subasic/cmdLIST.inc
        .include subasic/cmdNEW.inc

        ;
        ; Subroutines for the BASIC utilities
        ;

        .include subasic/EDITOR.inc
        .include subasic/KEYBOARD.inc
        .include subasic/FINDLINE.inc
        .include subasic/PARSEEXPRESSION.inc
        .include subasic/GETTOKEN.inc
        .include subasic/VARIABLES.inc
        .include subasic/debug.inc


;-----------------------------------------------------------------------------
; BASIC PROGRAM SOURCE CODE
;-----------------------------------------------------------------------------

        .org 0x7000

program:                                ; The program source code to be run
L2:      .data 2,    L5-$-1,    "LET A=64",                    0
L5:      .data 5,    L10-$-1,    "PRINT \"Start\"",                    0        
L10:     .data 10,    L20-$-1,    "FOR A = 1 TO 10",                    0
L20:     .data 20,    L30-$-1,    "PRINT A",                   0
L30:     .data 30,    L40-$-1,    "NEXT A",                  0
L40:     .data 50,    Lend-$-1,    "END",        0
Lend:    .data 0
