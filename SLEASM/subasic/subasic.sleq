L10:     .data 10,    L20-$-1,    "LET A=5",                    0
L20:     .data 20,    L30-$-1,    "LET B=80",                   0
L30:     .data 30,    L40-$-1,    "LET C=A+B",                  0
L40:     .data 40,    L50-$-1,    "PRINT C+0",                    0
L50:     .data 50,    L60-$-1,    "PRINT \"PLUS 1 IS \"",        0
L60:     .data 60,    L100-$-1,   "PRINT C+1",                  0
L100:    .data 100,   L110-$-1,   "GOSUB 10000",                0
L110:    .data 110,   L120-$-1,   "GOTO 9999",                  0
L120:    .data 120,   L9999-$-1,  "PRINT \"Should not get here\"", 0
L9999:   .data 9999,  L10000-$-1, "END",                        0
L10000:  .data 10000, L10010-$-1, "PRINT \"In subroutine\"",    0
L10010:  .data 10010, Lend-$-1,   "RETURN",                     0
Lend:    .data 0
