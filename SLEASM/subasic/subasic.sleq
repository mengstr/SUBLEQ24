            .include MACROS.inc

            .org 0

Z:          .data 0 
PLUS1:      .data 1 
MINUS1:     .data (-1)
            JMP Start

tokenNum:       .data 0
tokenVar:       .data 0

tmpA:       .data 0             ; Used by macros
tmpB:       .data 0             ; Used by macros
tmpC:       .data 0             ; Used by macros

ch:         .data 0             ; Used by tokenizing

val_:       .data val
val:        .data 0


pProgram_:  .data pProgram              ; pProgram_ is a constant holding the address of the pProgram pointer
pProgram:   .data 0                     ; pProgram is a pointer to the code array

program_:   .data program               ; program_ is a constant holding the address of the program array


lineNo:             .data 0
offsetNextLine:   .data 0
q:                  .data 0

;-----------------------------------------------------------------------------
; START OF SUBLEQ CODE
;-----------------------------------------------------------------------------

delStart:       .data 0
delLen:         .data 0
bufLen:         .data 0
pS:        .data 0
pD:        .data 0
cnt:       .data 0

CONST_256:      .data 256
CONST_x20:       .data 0x20
CONST_x40:       .data 0x40
CONST_x555:     .data 0x555

Start:
        MOV stack_ SP                              ; Initialize the stack pointer

        PUSH msgLogo
        CALL PrintString

;        PUSH program            ; Point to start of the array to manipulate
;        PUSH CONST_256          ; Total length of the array
;        PUSH CONST_x40          ; Offset into the array where the manipulated block starts
;        PUSH CONST_8            ; Length of the manipulated block
;        CALL DeleteBlock


 ;       PUSH program            ; Point to start of the array to manipulate
 ;       PUSH CONST_256          ; Total length of the array
 ;       PUSH CONST_x20          ; Offset into the array where the manipulated block starts
 ;       PUSH CONST_8            ; Length of the manipulated block
 ;       CALL InsertBlock

;-----------------------------------------------------------------------------
; COMMAND LINE PROMPT
;-----------------------------------------------------------------------------
Prompt:
        PRINTCRLF
        OUT ASCII_GREATER

        CALL InputString        
        MOV buf pProgram
        CALL GetToken
        CALL ParseToken
        PRINTCRLF

        CMPEQ tokenType CONST_6 Editor          ; Starts with a number, so it's an editor command
        CMPNE tokenType CONST_3 Syntax          ; If it's not a keyword, it's a syntax error
        CMPEQ tokenValue kwLIST PromptLIST
        CMPEQ tokenValue kwRUN PromptRUN
        CMPEQ tokenValue kwNEW PromptNEW
        JMP Prompt

Syntax:
        PUSH msgSyntaxError
        CALL PrintString
        JMP Prompt

PromptLIST:
        CALL cmdLIST
        JMP Prompt

PromptNEW:
        CLR program
        JMP Prompt

PromptRUN:
        MOV program_ pProgram               


newProgramLine:
        INDEXEDRD pProgram lineNo           ; Get Linenumber of current line as a binary value
        JEQZ lineNo cmdEND                    ; If we reach the end of the program, halt
        INC pProgram

        INDEXEDRD pProgram offsetNextLine ; Get offset to next line
        INC pProgram

        CALL debugShowLine  ; Prints the entire line in magenta

loop:
        CALL GetToken
        CALL ParseToken

        CMPEQ tokenType CONST_0 Syntax
        CMPEQ tokenType CONST_1 newProgramLine
;       CMPEQ tokenType CONST_2 newProgramLine
        CMPEQ tokenType CONST_3 kw
    
        JMP loop


kw:
        CMPEQ tokenValue kwEND cmdEND
        CMPEQ tokenValue kwPRINT cmdPRINT
        CMPEQ tokenValue kwGOTO cmdGOTO
        CMPEQ tokenValue kwLET cmdLET
        CMPEQ tokenValue kwGOSUB cmdGOSUB
        CMPEQ tokenValue kwRETURN cmdRETURN
        CMPEQ tokenValue kwLIST cmdLIST
        JMP Syntax


;-----------------------------------------------------------------------------
        .proc cmdLIST
@p:             .data 0
@lineNo:        .data 0
@ch:            .data 0

cmdLIST:
;-----------------------------------------------------------------------------
        MOV program_ @p                 ; Point to start of source code

@loop: 
        INDEXEDRD @p @lineNo            ; Get Linenumber of current line as a binary value
        INC @p
        JEQZ @lineNo @done              ; Reached the end of the code?

        PUSH @lineNo                    ; Print the line number and a space
        CALL PrintInteger
        OUT ASCII_SPACE

        INC @p                          ; Skip the offset to the next line

@loop1:
        INDEXEDRD @p @ch                ; Get Linenumber of current line as a binary value
        INC @p
        JEQZ @ch @eol                   ; Reached the end of the line?
        OUT @ch                         ; Print the character
        JMP @loop1      

@eol:
        PRINTCRLF                       ; Print a CRLF and go print the next line
        JMP @loop

@done:
        RET

        .endp

;-----------------------------------------------------------------------------
cmdEND:
;-----------------------------------------------------------------------------
    JMP Prompt

;-----------------------------------------------------------------------------
cmdPRINT:
;-----------------------------------------------------------------------------
        CALL ParseExpression
        CMPEQ tokenType CONST_5 cmdPRINTstring 
        PUSH expression
        CALL PrintInteger
        JMP newProgramLine
cmdPRINTstring:
        PUSH token1
        CALL PrintString
        JMP loop

letDest: .data 0

;-----------------------------------------------------------------------------
cmdLET:
;-----------------------------------------------------------------------------
        CALL GetToken
        CALL ParseToken
        MOV tokenVariable letDest

        CALL ParseExpression
        INDEXEDWR expression letDest
        JMP newProgramLine


;-----------------------------------------------------------------------------
cmdGOTO:
;-----------------------------------------------------------------------------
        CALL ParseExpression
        PUSH expression
        CALL FindLine
        MOV  pFound pProgram
        JMP newProgramLine

;-----------------------------------------------------------------------------
cmdGOSUB:
;-----------------------------------------------------------------------------
        PUSH pProgram
        CALL ParseExpression
        PUSH expression
        CALL FindLine
        MOV  pFound pProgram
        JMP newProgramLine

;-----------------------------------------------------------------------------
cmdRETURN:
;-----------------------------------------------------------------------------
        POP pProgram
        JMP loop

 
;-----------------------------------------------------------------------------
; MESSAGE STRINGS
;-----------------------------------------------------------------------------

msgLogo:        
        .data $+1
        .data "\r\n"
        .data " __        __        ___  __     ___                __        __     __  "       ,"\r\n"
        .data "/__` |  | |__) |    |__  /  \\     |  | |\\ | \\ /    |__)  /\\  /__` | /  ` "       ,"\r\n"
        .data ".__/ \\__/ |__) |___ |___ \\__\\\\    |  | | \\|  |     |__) /--\\ .__/ | \\__, "       ,"\r\n"
        .data "\r\n"
        .data "[ ver 0.00 - (c) 2024 Mats Engstrom - github.com/mengstr/sleqTinyBasic ]\r\n", 0
        .data "\r\n"

        .data 0                                         

msgEnd:         .data $+1, "\r\nExecution halted by END\r\n", 0
msgEndOfFile:   .data $+1 "\r\nExecution halted by End Of File\r\n", 0
msgSyntaxError: .data $+1 "\r\nSyntax error\r\n", 0
msgLineNotFound:.data $+1 "\r\nLine not found\r\n", 0

