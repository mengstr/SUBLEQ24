            .include MACROS.inc

            .org 0

Z:          .data 0 
PLUS1:      .data 1 
MINUS1:     .data (-1)
            JMP Start


tmpA:       .data 0             ;Used by macros
tmpB:       .data 0             ;Used by macros
ch:         .data 0             ;Used by tokenizing

val_:       .data val
val:        .data 0


pProgram_:  .data pProgram              ; pProgram_ is a constant holding the address of the pProgram pointer
pProgram:   .data 0                     ; pProgram is a pointer to the code array

program_:   .data program               ; program_ is a constant holding the address of the program array
program:                                ; The program source code to be run



;L10:         .data 10,  L20-$-1,  "GOTO 100",           "\0"
