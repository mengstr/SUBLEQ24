;Lend:        .data 0

L10:         .data 10,  L20-$-1,  "GOTO 100",           "\0"
L20:         .data 20,  L100-$-1, "END",                "\0"
L100:        .data 100, L105-$-1, "PRINT 'Hello,'",     "\0"
L105:        .data 105, L110-$-1, "PRINT ' world!'",    "\0"
L110:        .data 110, L120-$-1, "PRINT 1234",         "\0" 
L120:        .data 120, L121-$-1, "PRINT Q",            "\0"
L121:        .data 121, L122-$-1, "LET Q=4711",         "\0"
L122:        .data 122, L130-$-1, "PRINT Q",            "\0"
L130:        .data 130, L131-$-1, "LET A=1",            "\0"
L131:        .data 131, L132-$-1, "LET B=10",           "\0"
L132:        .data 132, L133-$-1, "LET C=100",          "\0"
L133:        .data 133, L140-$-1, "LET D=1000",         "\0"
L140:        .data 140, L141-$-1, "LET E = A + B + C + D",      "\0"
L141:        .data 141, L150-$-1, "PRINT E",            "\0"
L150:        .data 150, L151-$-1, "LET F=1+2+3+4+5",    "\0"
L151:        .data 151, L160-$-1, "PRINT F",            "\0"
L160:        .data 160, Lend-$-1, "GOTO 20",            "\0"
Lend:        .data 0


lineNo:             .data 0
offsetToNextLine:   .data 0
q:                  .data 0

msgEXECUTING: .data $+1
         .data "Executing line number \0"


Stop:
    PUSH msgEndOfFile
    CALL PrintString
    HALT

Start:
    MOV stack_ SP                              ; Initialize the stack pointer

    PUSH msgLogo
    CALL PrintString
    MOV program_ pProgram               

    CALL GetToken
    PUSH token
    CALL PrintString
    HALT



MainLoop:
    INDEXEDRD pProgram lineNo           ; Get Linenumber of current line as a binary value
    JEQZ lineNo stop                    ; If we reach the end of the program, halt
    INC pProgram

    INDEXEDRD pProgram offsetToNextLine ; Get offset to next line
    INC pProgram

    CALL debugShowLine  ; Prints the entire line in magenta

TokenLoop:
    CALL GetToken                       ; Get the next token
    CALL debugTokenType

    CMPEQ CONST_1 tokenType MainLoop    ; IF EOL then go up and fetch the next line
    CMPEQ CONST_3 tokenType tokenIsKeyword
    JMP TokenLoop

tokenIsKeyword:
    CMPEQ tokenNum kwEND cmdEND
    CMPEQ tokenNum kwLET cmdLET
    CMPEQ tokenNum kwGOTO cmdGOTO
    CMPEQ tokenNum kwPRINT cmdPRINT
    HALT


;-----------------------------------------------------------------------------------------------------
; COMMAND - END
;-----------------------------------------------------------------------------------------------------
cmdEND:
    PUSH msgEnd
    CALL PrintString
    HALT


;-----------------------------------------------------------------------------------------------------
;COMMAND - GOTO
;-----------------------------------------------------------------------------------------------------
cmdGOTO:
    CALL GetToken                    ; Get the destination token

    MOV program_ pLine               ;Point to start of source code
findLineLoop:
    INDEXEDRD pLine lineNo           ; Get Linenumber of current line as a binary value
    JEQZ lineNo notFound             ; If we reach the end of the program, the line was not found
    INC pLine

    INDEXEDRD pLine offsetToNextLine ; Get offset to next line
    INC pLine

    val lineNo                           ; Compare val (the desination target) with the current line number
    JEQZ lineNo foundLine                ; If they are equal, jump to the destination line

    ADD offsetToNextLine pLine      ; Otherwise, skip to the next line
    JMP findLineLoop

foundLine:
    DEC pLine                       ; Back up to beginning of line 
    DEC pLine
    MOV pLine pProgram              ; ... and set the program pointer to the start of the line
    JMP MainLoop                        ; ... to continue execution there

notFound:
    PUSH msgLineNotFound
    CALL PrintString
    HALT



;-----------------------------------------------------------------------------------------------------
; COMMAND - LET
;-----------------------------------------------------------------------------------------------------

cmdLET:
    CALL GetToken                      ; Get the next token (the variable to be assigned)
    MOV tokenVar expressionVariable

    CALL GetToken                      ; Get the next token (the equal-sign)


handleExpression:
    CLR expressionValue
expressionLoop:
    CALL GetToken                       ; Get the next token
    CMPEQ CONST_1 tokenType expDone     ; end of line
    CMPEQ CONST_2 tokenType expDone     ; end of stetement (a colon)
    CMPEQ CONST_4 tokenType expOp       ; operator
    CMPEQ CONST_6 tokenType expNum      ; numeric value
    CMPEQ CONST_7 tokenType expNum      ; variable
    PUSH msgSyntaxError
    CALL PrintString
    HALT 

expDone:
    INDEXEDWR expressionValue expressionVariable
    JMP MainLoop    ;TODO - Go to tokenLoop if we got a colon

expOp:
    OUT ASCII_y
    JMP expressionLoop

expNum:
    MOV tokenNum expressionValue
    JMP expressionLoop

expressionVariable: .data 0
expressionValue:    .data 0


;-----------------------------------------------------------------------------------------------------
; COMMAND - PRINT
;-----------------------------------------------------------------------------------------------------
cmdPRINT:
    CALL GetToken                      ; Get the next token
    CMPEQ CONST_5 tokenType cmdPRINTstring
    CMPEQ CONST_6 tokenType cmdPRINTnumber
    CMPEQ CONST_7 tokenType cmdPRINTvariable
    HALT

cmdPRINTstring:
    PUSH tokenStr_
    CALL PrintString
    CALL debugCRLF
    JMP TokenLoop

cmdPRINTnumber:
    PUSH tokenNum
    CALL PrintInteger
    CALL debugCRLF
    JMP TokenLoop

cmdPRINTvariable:
    PUSH tokenNum
    CALL PrintInteger
    CALL debugCRLF
    JMP TokenLoop


