    .org 0

start:
    zero  message  (-1)  ; subtract 0 from next character value to print;
                                ; terminate if it's <=0
    message (-1)  (-1)   ; output character
    neg1  start+1  (-1)    ; modify above two instructions by subtracting -1 
    neg1  start+3  (-1)    ;   (adding 1) to their target addresses 
    zero  zero   start   ; if 0-0 <= 0 (i.e. always) goto start


; useful constants
zero: 
    .data 0  
neg1: 
    .data (-1)

; the message to print
message: .data "Hello, world!\n\0"


