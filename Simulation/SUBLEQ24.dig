    <visualElement>
      <elementName>LED</elementName>
      <elementAttributes>
        <entry>
          <string>Size</string>
          <int>3</int>
        </entry>
        <entry>
          <string>Color</string>
          <awt-color>
            <red>153</red>
            <green>255</green>
            <blue>153</blue>
            <alpha>255</alpha>
          </awt-color>
        </entry>
      </elementAttributes>
      <pos x="3860" y="1720"/>
    </visualElement>
    <visualElement>
      <elementName>Text</elementName>
      <elementAttributes>
        <entry>
          <string>textFontSize</string>
          <int>22</int>
        </entry>
        <entry>
          <string>Description</string>
          <string>T0
........Output PC+0 to Address bus
........RAM outputs A-address to Data bus

T1
........Latch A-address into register
........Increment PC
........Output PC+1to Address bus
........(RAM outputs address of B to Data bus)


T2
........A-address register output to Address bus
........RAM outputs value of data poited to by A to Data bus

T3
........A-address register output to Address bus
........RAM outputs value of [A] to Data bus
........Latch value of [A] into A value register

T4
........Output PC+1 to Address bus
........RAM outputs address of B to Data bus

T5
........Latch B-address into register
........Increment PC
........(Output PC+2 to Address bus)
........(RAM outputs B-address to Data bus)

T6
........B-address register output to Address bus
........RAM outputs value [B] to Data bus

T7
........B-address register output to Address bus
........RAM outputs value of [B] to Data bus
........Latch value of [B] into B value register

T8
........B-address register output to Address bus
........RAM outputs value of [B] to Data bus

T9
........B-address register output to Address bus
........Subtractor output [B]-[A] to Data bus
........Write subtaction result into RAM pointef to B-address

T10
........B-address register output to Address bus
........RAM outputs value of [B] to Data bus

T11
........RAM outputs value of &lt;random HiZ&gt; to Data bus

T12
........RAM outputs value of &lt;random HiZ&gt; to Data bus

T13
........Output PC+2 to Address bus
........RAM outputs [C] to Data bus

T14 (not LEQ)
........Increment PC
........(Output PC+3 (next instruction) to Address bus)
........(RAM outputs A-address to Data bus)

T14 (LEQ)
........Load PC with [C] from Data bus
........

T15
........(Output PC+3 (next instruction) to Address bus
........(RAM outputs value of (next instruction) A-address to Data bus)</string>
        </entry>
      </elementAttributes>
      <pos x="4080" y="-200"/>
    </visualElement>
