  31:printf.c      **** static void uli2a(unsigned long int num, unsigned int base, int uc,char * bf)
  32:printf.c      ****     {
  33:printf.c      ****     int n=0;
  34:printf.c      ****     unsigned int d=1;
  35:printf.c      ****     while (num/d >= base)
  36:printf.c      ****         d*=base;         
  37:printf.c      ****     while (d!=0) {
  38:printf.c      ****         int dgt = num / d;
  39:printf.c      ****         num%=d;
  40:printf.c      ****         d/=base;
  41:printf.c      ****         if (n || dgt>0|| d==0) {
  42:printf.c      ****             *bf++ = dgt+(dgt<10 ? '0' : (uc ? 'A' : 'a')-10);
  43:printf.c      ****             ++n;
  44:printf.c      ****             }
  45:printf.c      ****         }
  46:printf.c      ****     *bf=0;
  47:printf.c      ****     }
  48:printf.c      **** 
  49:printf.c      **** static void li2a (long num, char * bf)
  50:printf.c      ****     {
  51:printf.c      ****     if (num<0) {
  52:printf.c      ****         num=-num;
  53:printf.c      ****         *bf++ = '-';
  54:printf.c      ****         }
  55:printf.c      ****     uli2a(num,10,0,bf);
  56:printf.c      ****     }
  57:printf.c      **** 
  58:printf.c      **** #endif
