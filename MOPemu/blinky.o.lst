  58:blinky.c      **** 
  59:blinky.c      **** #define GPIO_PIN(name, port, pin)                                              \
  60:blinky.c      ****   static inline void GPIO_##name##_pp(void) {                                  \
  61:blinky.c      ****     if (pin > 7) {                                                             \
  62:blinky.c      ****       GPIO##port->CRH &= ~(0xF << ((pin - 8) * 4));                                                
  63:blinky.c      ****       GPIO##port->CRH |= (GPIO_CRH_MODE8_0 << ((pin - 8) * 4));                \
  64:blinky.c      ****     } else {                                                                   \
  65:blinky.c      ****       GPIO##port->CRL &= ~(0xF << (pin * 4));                                                     \
  66:blinky.c      ****       GPIO##port->CRL |= (GPIO_CRL_MODE0_0 << (pin * 4));                      \
  67:blinky.c      ****     }                                                                          \
  68:blinky.c      ****     (void)GPIO_##name##_pp;                                                    \
  69:blinky.c      ****   }                                                                            \
  70:blinky.c      ****                                                                                \
  71:blinky.c      ****   static inline void GPIO_##name##_set(void) {                                 \
  72:blinky.c      ****     GPIO##port->BSRR = GPIO_BSRR_BS0 << pin;                                   \
  73:blinky.c      ****     (void)GPIO_##name##_set;                                                   \
  74:blinky.c      ****   }                                                                            \
  75:blinky.c      ****                                                                                \
  76:blinky.c      ****   static inline void GPIO_##name##_clr(void) {                                 \
  77:blinky.c      ****     GPIO##port->BRR = GPIO_BRR_BR0 << pin;                                     \
  78:blinky.c      ****     (void)GPIO_##name##_clr;                                                   \
  79:blinky.c      ****   }                                                                            \
  80:blinky.c      ****   static inline bool GPIO_##name##_read(void) {                              \
  81:blinky.c      ****     return (GPIO##port->IDR >> pin) & 1;                                       \
  82:blinky.c      ****   }                                                                            \
  83:blinky.c      ****                                                                                \
  84:blinky.c      **** /*  Floating: To configure a GPIO pin as an input with floating, you need to 
  85:blinky.c      ****               set the corresponding CNFy bits to '01'.
  86:blinky.c      **** 
  87:blinky.c      ****   GPIOA->CRL &= ~(GPIO_CRL_CNF1 | GPIO_CRL_MODE1); // Reset CNF and MODE bits
  88:blinky.c      ****   GPIOA->CRL |= GPIO_CRL_CNF1_0; // Set CNF bits to '01' for floating input
  89:blinky.c      ****                                                                             */ \
  90:blinky.c      ****   static inline void GPIO_##name##_inFloat(void) {                             \
  91:blinky.c      ****     if (pin > 7) {                                                             \
  92:blinky.c      ****       GPIO##port->CRH &= ~(0xF << ((pin - 8) * 4));                                                
  93:blinky.c      ****     } else {                                                                   \
  94:blinky.c      ****       GPIO##port->CRL &= ~(0xF << (pin * 4));                                                     \
  95:blinky.c      ****     }                                                                          \
  96:blinky.c      ****     (void)GPIO_##name##_inFloat;                                               \
  97:blinky.c      ****   }                                                                            \
  98:blinky.c      ****                                                                                \
  99:blinky.c      **** /*  Pull-up: To configure a GPIO pin as an input with pull-up, you need to 
 100:blinky.c      ****             set the corresponding CNFy bits to '10' and 
 101:blinky.c      ****             set the corresponding ODRy bit to '1'.
 102:blinky.c      **** 
 103:blinky.c      ****   GPIOA->CRL &= ~(GPIO_CRL_CNF1 | GPIO_CRL_MODE1); // Reset CNF and MODE bits
 104:blinky.c      ****   GPIOA->CRL |= GPIO_CRL_CNF1_1; // Set CNF bits to '10' for pull-up/pull-down
 105:blinky.c      ****   GPIOA->ODR |= GPIO_ODR_ODR1; // Set ODR bit to '1' for pull-up
 106:blinky.c      ****                                                                             */ \
 107:blinky.c      ****   static inline void GPIO_##name##_inPU(void) {                                \
 108:blinky.c      ****     if (pin > 7) {                                                             \
 109:blinky.c      ****       GPIO##port->CRH &= ~(0xF << ((pin - 8) * 4));                                                
 110:blinky.c      ****       GPIO##port->CRH |=  ((GPIO_CRH_CNF8_1)<< ((pin - 8) * 4)); \
 111:blinky.c      ****     } else {                                                                   \
 112:blinky.c      ****       GPIO##port->CRL &= ~(0xF << (pin * 4));                                                     \
 113:blinky.c      ****       GPIO##port->CRL |=  ((GPIO_CRL_CNF0_1) << (pin * 4));     \
 114:blinky.c      ****     }                                                                          \
 115:blinky.c      ****     GPIO##port->BSRR = 1 << pin;                                   \
 116:blinky.c      ****     (void)GPIO_##name##_inPU;                                                  \
 117:blinky.c      ****   }                                                                            \
 118:blinky.c      ****                                                                                \
 119:blinky.c      **** /* Pull-down: To configure a GPIO pin as an input with pull-down, you need 
 120:blinky.c      ****               to set the corresponding CNFy bits to '10' and set 
 121:blinky.c      ****               the corresponding ODRy bit to '0'.
 122:blinky.c      **** 
 123:blinky.c      **** GPIOA->CRL &= ~(GPIO_CRL_CNF1 | GPIO_CRL_MODE1); // Reset CNF and MODE bits
 124:blinky.c      **** GPIOA->CRL |= GPIO_CRL_CNF1_1; // Set CNF bits to '10' for pull-up/pull-down
 125:blinky.c      **** GPIOA->ODR &= ~GPIO_ODR_ODR1; // Set ODR bit to '0' for pull-down
 126:blinky.c      ****                                                                             */ \
 127:blinky.c      ****   static inline void GPIO_##name##_inPD(void) {                                \
 128:blinky.c      ****     if (pin > 7) {                                                             \
 129:blinky.c      ****       GPIO##port->CRH &= ~(0xF << ((pin - 8) * 4));                                                
 130:blinky.c      ****       GPIO##port->CRH |= ((GPIO_CRH_CNF8_1)<< ((pin - 8) * 4));                 \
 131:blinky.c      ****     } else {                                                                    \
 132:blinky.c      ****       GPIO##port->CRL &= ~(0xF << (pin * 4));                                                     \
 133:blinky.c      ****       GPIO##port->CRL |=  ((GPIO_CRL_CNF0_1) << (pin * 4));                       \
 134:blinky.c      ****     }                                                                           \
 135:blinky.c      ****     GPIO##port->BSRR = 1 << (16+pin);                                           \
 136:blinky.c      ****     (void)GPIO_##name##_inPD;                                                   \
 137:blinky.c      ****   }                                                                            
